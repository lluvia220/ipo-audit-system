{
  "name": "ipo-audit-system",
  "version": "1.0.0",
  "description": "IPO审核动态查询系统",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && python3 -m http.server 8080",
    "dev:backend": "cd backend && node server.js",
    "start": "npm run dev",
    "build": "echo 'Build complete'",
    "deploy:frontend": "vercel deploy --name ipo-audit-frontend",
    "deploy:backend": "vercel deploy --name ipo-audit-backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}